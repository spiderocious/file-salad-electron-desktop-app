{
  "name": "file-salad-electron",
  "version": "0.1.0",
  "private": true,
  "description": "FileSalad — macOS menu-bar app. Drop a file, get a public link.",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf out dist release coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "aws4": "^1.13.2",
    "clsx": "^2.1.1",
    "file-salad-ui-lib": "github:spiderocious/file-salad-ui-lib#v0.1.1",
    "lucide-react": "^0.469.0",
    "meemaw": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/aws4": "^1.11.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-import-resolver-typescript": "^3.8.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "^25.0.1",
    "msw": "^2.6.0",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.5"
  }
}
